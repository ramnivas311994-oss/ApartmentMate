{
  "name": "apartmate-backend",
  "version": "1.0.0",
  "description": "ApartMate - Apartment Payment Management System API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:init": "psql -h localhost -U postgres -d apartmate_db -f apartmate_schema.sql",
    "db:migrate": "node migrations/run.js",
    "db:seed": "node scripts/seed.js",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "build": "echo 'No build step required for Node.js'",
    "pm2:start": "pm2 start server.js --name 'apartmate-api'",
    "pm2:logs": "pm2 logs apartmate-api",
    "pm2:stop": "pm2 stop apartmate-api",
    "pm2:restart": "pm2 restart apartmate-api",
    "docker:build": "docker build -t apartmate-api:latest .",
    "docker:run": "docker run -p 3000:3000 --env-file .env apartmate-api:latest"
  },
  "keywords": [
    "apartment",
    "payment",
    "management",
    "building",
    "maintenance"
  ],
  "author": "ApartMate Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "pg-escape": "^1.0.0",
    "razorpay": "^2.9.0",
    "stripe": "^14.0.0",
    "twilio": "^4.0.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "node-cache": "^5.1.2",
    "moment": "^2.29.4",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "jest-postgresql": "^0.0.1",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/apartmate-backend.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/apartmate-backend/issues"
  },
  "homepage": "https://github.com/yourusername/apartmate-backend#readme",
  "nodemonConfig": {
    "watch": [
      "*.js",
      "routes",
      "controllers",
      "middleware"
    ],
    "ignore": [
      "node_modules",
      "*.test.js"
    ],
    "delay": 1000
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!dist/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  }
}
