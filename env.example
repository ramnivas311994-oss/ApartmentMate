# ApartMate Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================================
# NODE & SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=apartmate_db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# For AWS RDS:
# DB_HOST=apartmate-db.c9akciq32.us-east-1.rds.amazonaws.com
# DB_PORT=5432
# DB_NAME=apartmate_db
# DB_USER=postgres
# DB_PASSWORD=your_rds_password

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=24h
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================================
# FIREBASE CLOUD MESSAGING (Notifications)
# ============================================================
# Download Firebase Service Account Key from Firebase Console > Project Settings
FIREBASE_ADMIN_KEY={"type":"service_account","project_id":"your_project_id",...}
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ============================================================
# PAYMENT GATEWAY - RAZORPAY
# ============================================================
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# For Testing (Sandbox):
# RAZORPAY_KEY_ID=rzp_test_1234567890
# RAZORPAY_KEY_SECRET=test_secret_key

# ============================================================
# PAYMENT GATEWAY - STRIPE (Alternative)
# ============================================================
STRIPE_PUBLIC_KEY=pk_live_your_public_key
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================================
# SMS NOTIFICATIONS - TWILIO
# ============================================================
# Get credentials from: https://www.twilio.com/console
TWILIO_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# WHATSAPP INTEGRATION - TWILIO or WhatsApp Business API
# ============================================================
# Option 1: Twilio WhatsApp Sandbox
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Option 2: WhatsApp Business API
WHATSAPP_API_URL=https://graph.instagram.com/v17.0/
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_TOKEN=your_access_token

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
# Using SendGrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@apartmate.com
SENDGRID_FROM_NAME=ApartMate Team

# Using AWS SES
# AWS_SES_REGION=us-east-1
# AWS_SES_FROM_EMAIL=noreply@apartmate.com

# ============================================================
# AWS CONFIGURATION
# ============================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS S3 for file uploads
AWS_S3_BUCKET_NAME=apartmate-uploads
AWS_S3_REGION=us-east-1

# AWS CloudWatch (Logging)
AWS_CLOUDWATCH_GROUP=/aws/apartmate/api
AWS_CLOUDWATCH_STREAM=production

# ============================================================
# PAYMENT DOMAIN
# ============================================================
# Used for generating payment links
PAYMENT_DOMAIN=https://pay.apartmate.in
API_DOMAIN=https://api.apartmate.in
WEB_DOMAIN=https://apartmate.in

# For local development:
# PAYMENT_DOMAIN=http://localhost:3000
# API_DOMAIN=http://localhost:3000
# WEB_DOMAIN=http://localhost:3001

# ============================================================
# MONITORING & LOGGING
# ============================================================
# Using Datadog
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

# Using Sentry
SENTRY_DSN=https://your_key@sentry.io/project_id

# Using NewRelic
NEW_RELIC_LICENSE_KEY=your_newrelic_license_key
NEW_RELIC_APP_NAME=apartmate-api

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window

# ============================================================
# SESSION CONFIGURATION
# ============================================================
SESSION_SECRET=your_session_secret_key_change_this
SESSION_TIMEOUT=86400  # 24 hours in seconds

# ============================================================
# ADMIN SETTINGS
# ============================================================
ADMIN_EMAIL=admin@apartmate.com
ADMIN_PHONE=9876543210
SUPPORT_EMAIL=support@apartmate.com
SUPPORT_PHONE=9876543210

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_PAYMENT_GATEWAY=true
ENABLE_WHATSAPP_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true

# ============================================================
# MAINTENANCE & BACKUP
# ============================================================
DB_BACKUP_ENABLED=true
DB_BACKUP_TIME=02:00  # 2 AM
DB_BACKUP_RETENTION_DAYS=30

# ============================================================
# TESTING
# ============================================================
TEST_MODE=false
MOCK_PAYMENT_GATEWAY=false
